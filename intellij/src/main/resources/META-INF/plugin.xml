<idea-plugin>
  <id>com.flyingdice.neoc</id>
  <name>neoc (Neoc)</name>
  <vendor email="hello@flying-dice.com" url="https://github.com/flying-dice/neoc-compiler">Flying Dice</vendor>

  <description><![CDATA[
    <h2>neoc language support for WebStorm</h2>
    <p>
      Syntax highlighting, completion, hover, diagnostics, and quick-fixes
      for <a href="https://github.com/flying-dice/neoc-compiler">neoc</a> — a
      Rust-flavoured TypeScript dialect.
    </p>
    <p>
      Semantic features come from the neoc LSP server. Install neoc so
      that <code>neoc lsp</code> resolves on your PATH, then open any
      <code>.neoc</code> file.
    </p>
  ]]></description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
      name="neoc"
      implementationClass="com.flyingdice.neoc.NeocFileType"
      fieldName="INSTANCE"
      language="neoc"
      extensions="neoc"/>

    <lang.parserDefinition
      language="neoc"
      implementationClass="com.flyingdice.neoc.NeocParserDefinition"/>

    <lang.syntaxHighlighterFactory
      language="neoc"
      implementationClass="com.flyingdice.neoc.NeocSyntaxHighlighterFactory"/>

    <platform.lsp.serverSupportProvider
      implementation="com.flyingdice.neoc.NeocLspServerSupportProvider"/>
  </extensions>
</idea-plugin>
