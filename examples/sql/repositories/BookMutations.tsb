import type { Database } from "bun:sqlite";
import type { Book } from "../entities/Book.ts";

#[sql("insert-book")]
export function insertBook(
  db: Database,
  id: string,
  title: string,
  author: string,
  copies: number,
): void {}

#[sql("update-book-copies")]
export function updateBookCopies(
  db: Database,
  id: string,
  copies: number,
): Book | undefined {}
