/// `match` is a value-yielding expression with four pattern kinds:
/// wildcard `_`, literal, binding identifier, struct/object pattern.
/// Lowers to a Lua IIFE.
struct Cat {}
struct Dog {}

pub fn sound(animal: Cat | Dog) -> string {
  return match animal {
    Cat => "meow",
    Dog => "woof",
    _ => "unknown",
  }
}

pub fn describe(x: number) -> string {
  return match x {
    0 => "zero",
    1 => "one",
    n => "many: " .. tostring(n),
  }
}
