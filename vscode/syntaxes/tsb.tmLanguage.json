{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "tsb",
  "scopeName": "source.tsb",
  "fileTypes": ["tsb"],
  "patterns": [
    { "include": "#tsb-attribute" },
    { "include": "#tsb-keywords" },
    { "include": "#tsb-match-keyword" },
    { "include": "source.ts" }
  ],
  "repository": {
    "tsb-keywords": {
      "match": "\\b(struct|impl|Self)\\b",
      "name": "keyword.declaration.tsb"
    },
    "tsb-match-keyword": {
      "match": "\\b(match)\\b",
      "name": "keyword.control.match.tsb"
    },
    "tsb-attribute": {
      "begin": "#\\[",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.attribute.tsb" }
      },
      "end": "\\]",
      "endCaptures": {
        "0": { "name": "punctuation.definition.attribute.tsb" }
      },
      "name": "meta.attribute.tsb",
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.macro.tsb" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.tag.tsb"
        },
        {
          "begin": "\\(",
          "end": "\\)",
          "name": "meta.attribute.args.tsb",
          "patterns": [
            { "include": "source.ts#string" },
            { "include": "source.ts#numeric-literal" },
            {
              "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
              "name": "variable.parameter.tsb"
            },
            { "match": ",", "name": "punctuation.separator.tsb" }
          ]
        }
      ]
    }
  }
}
