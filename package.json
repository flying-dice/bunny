{
  "name": "@flying-dice/neoc",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "neoc": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./ast": "./src/neoc/ast/index.ts",
    "./parser": "./src/neoc/parser/index.ts",
    "./codegen-lua": "./src/neoc/codegen/lua/index.ts",
    "./compiler": "./src/neoc/compiler.ts",
    "./macro": "./src/neoc/macros/api.ts"
  },
  "scripts": {
    "test": "bun test",
    "example": "cd examples && bun ../src/cli.ts build -s 'showcase.neoc'",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.9"
  }
}
